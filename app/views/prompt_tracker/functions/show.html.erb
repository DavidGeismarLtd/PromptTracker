<div class="container-fluid py-4">
  <!-- Header -->
  <div class="mb-4">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><%= link_to "Functions", functions_path %></li>
        <li class="breadcrumb-item active" aria-current="page"><%= @function.name %></li>
      </ol>
    </nav>
    <div class="d-flex justify-content-between align-items-start">
      <div>
        <h1 class="h2 mb-1">
          <i class="bi bi-code-square"></i> <%= @function.name %>
        </h1>
        <p class="text-muted"><%= @function.description %></p>
        <div class="mt-2">
          <span class="badge bg-info"><%= @function.category.titleize %></span>
          <code class="ms-2"><%= @function.language.upcase %></code>
          <% @function.tags.each do |tag| %>
            <span class="badge bg-secondary ms-1"><%= tag %></span>
          <% end %>
        </div>
      </div>
      <div>
        <%= link_to edit_function_path(@function), class: "btn btn-outline-primary" do %>
          <i class="bi bi-pencil"></i> Edit
        <% end %>
        <%= button_to function_path(@function), method: :delete, class: "btn btn-outline-danger", data: { confirm: "Are you sure you want to delete this function?" } do %>
          <i class="bi bi-trash"></i> Delete
        <% end %>
      </div>
    </div>
  </div>

  <!-- Stats -->
  <div class="row mb-4">
    <div class="col-md-3">
      <div class="card">
        <div class="card-body">
          <h6 class="text-muted mb-2">Total Executions</h6>
          <h3 class="mb-0"><%= number_with_delimiter(@total_executions) %></h3>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card">
        <div class="card-body">
          <h6 class="text-muted mb-2">Success Rate</h6>
          <h3 class="mb-0">
            <% if @total_executions > 0 %>
              <span class="badge <%= @success_rate >= 90 ? 'bg-success' : @success_rate >= 70 ? 'bg-warning' : 'bg-danger' %>" style="font-size: 1.5rem;">
                <%= number_to_percentage(@success_rate, precision: 1) %>
              </span>
            <% else %>
              <span class="text-muted">N/A</span>
            <% end %>
          </h3>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card">
        <div class="card-body">
          <h6 class="text-muted mb-2">Avg Execution Time</h6>
          <h3 class="mb-0">
            <% if @avg_execution_time %>
              <%= number_with_precision(@avg_execution_time, precision: 0) %>ms
            <% else %>
              <span class="text-muted">N/A</span>
            <% end %>
          </h3>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card">
        <div class="card-body">
          <h6 class="text-muted mb-2">Last Executed</h6>
          <h3 class="mb-0" style="font-size: 1rem;">
            <% if @function.last_executed_at %>
              <%= time_ago_in_words(@function.last_executed_at) %> ago
            <% else %>
              <span class="text-muted">Never</span>
            <% end %>
          </h3>
        </div>
      </div>
    </div>
  </div>

  <!-- Code -->
  <div class="card mb-4">
    <div class="card-header">
      <h5 class="mb-0">Function Code</h5>
    </div>
    <div class="card-body">
      <pre class="bg-light p-3 rounded"><code class="language-ruby"><%= @function.code %></code></pre>
    </div>
  </div>

  <!-- Parameters -->
  <div class="card mb-4">
    <div class="card-header">
      <h5 class="mb-0">Parameters</h5>
    </div>
    <div class="card-body">
      <% if @function.parameters.present? %>
        <pre class="bg-light p-3 rounded"><code class="language-json"><%= JSON.pretty_generate(@function.parameters) %></code></pre>
      <% else %>
        <p class="text-muted">No parameters defined</p>
      <% end %>
    </div>
  </div>

  <!-- Environment Variables -->
  <% if @function.environment_variables.present? %>
    <div class="card mb-4">
      <div class="card-header">
        <h5 class="mb-0">
          <i class="bi bi-shield-lock"></i> Environment Variables
        </h5>
      </div>
      <div class="card-body">
        <div class="alert alert-info">
          <i class="bi bi-info-circle"></i> Environment variables are encrypted and cannot be displayed for security reasons.
        </div>
        <p class="mb-0">Configured variables: <strong><%= @function.environment_variables.keys.join(", ") %></strong></p>
      </div>
    </div>
  <% end %>

  <!-- Dependencies -->
  <% if @function.dependencies.present? %>
    <div class="card mb-4">
      <div class="card-header">
        <h5 class="mb-0">Dependencies</h5>
      </div>
      <div class="card-body">
        <ul class="mb-0">
          <% @function.dependencies.each do |dep| %>
            <li><code><%= dep %></code></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <!-- Example -->
  <% if @function.example_input.present? || @function.example_output.present? %>
    <div class="card mb-4">
      <div class="card-header">
        <h5 class="mb-0">Example</h5>
      </div>
      <div class="card-body">
        <div class="row">
          <% if @function.example_input.present? %>
            <div class="col-md-6">
              <h6>Input</h6>
              <pre class="bg-light p-3 rounded"><code class="language-json"><%= @function.example_input %></code></pre>
            </div>
          <% end %>
          <% if @function.example_output.present? %>
            <div class="col-md-6">
              <h6>Output</h6>
              <pre class="bg-light p-3 rounded"><code class="language-json"><%= @function.example_output %></code></pre>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Execution History -->
  <div class="card">
    <div class="card-header">
      <h5 class="mb-0">Execution History</h5>
    </div>
    <div class="card-body">
      <% if @executions.any? %>
        <div class="table-responsive">
          <table class="table table-hover">
            <thead>
              <tr>
                <th>Executed At</th>
                <th>Status</th>
                <th>Arguments</th>
                <th>Result</th>
                <th>Execution Time</th>
              </tr>
            </thead>
            <tbody>
              <% @executions.each do |execution| %>
                <tr>
                  <td><%= execution.executed_at.strftime("%Y-%m-%d %H:%M:%S") %></td>
                  <td>
                    <% if execution.success %>
                      <span class="badge bg-success">Success</span>
                    <% else %>
                      <span class="badge bg-danger">Failed</span>
                    <% end %>
                  </td>
                  <td>
                    <% if execution.arguments.present? %>
                      <code><%= truncate(execution.arguments.to_json, length: 50) %></code>
                    <% else %>
                      <span class="text-muted">None</span>
                    <% end %>
                  </td>
                  <td>
                    <% if execution.success %>
                      <code><%= truncate(execution.result.to_json, length: 50) %></code>
                    <% else %>
                      <span class="text-danger"><%= truncate(execution.error_message, length: 50) %></span>
                    <% end %>
                  </td>
                  <td class="text-end">
                    <%= number_with_precision(execution.execution_time_ms, precision: 0) %>ms
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>

        <!-- Pagination -->
        <div class="mt-3">
          <%= paginate @executions %>
        </div>
      <% else %>
        <div class="text-center py-5">
          <i class="bi bi-clock-history" style="font-size: 3rem; color: #ccc;"></i>
          <p class="text-muted mt-3">No execution history yet</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
