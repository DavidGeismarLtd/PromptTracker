<%# Sync Buttons for Remote Entity (Push/Pull) %>
<%# Local variables:
    - version: The PromptVersion being edited
    - is_remote_entity_linked: Whether the API supports remote entity sync (used for initial visibility)
    - sync_status: Current sync status ('synced', 'pending', 'failed')
    - synced_at: Last sync timestamp
%>
<%# Always render sync buttons when version exists, but set initial visibility based on API capabilities %>
<%# JavaScript controller will handle dynamic visibility when provider/API changes %>
<% if version %>
  <% assistant_id = version.model_config&.dig("metadata", "assistant_id") %>

  <div class="btn-group ms-2"
       role="group"
       aria-label="Remote sync actions"
       data-controller="playground-sync-visibility"
       data-playground-sync-visibility-playground-ui-outlet="#playground-container"
       data-playground-sync-visibility-target="syncButtons"
       data-action="provider:changed@window->playground-sync-visibility#onProviderChange api:changed@window->playground-sync-visibility#onApiChange"
       style="<%= is_remote_entity_linked ? '' : 'display: none;' %>">
    <!-- Push to Remote (local → remote) -->
    <button type="button"
            class="btn btn-outline-primary"
            data-playground-sync-target="pushBtn"
            data-action="click->playground-sync#pushToRemote"
            title="Push local changes to remote entity">
      <i class="bi bi-cloud-arrow-up"></i> Push
      <% if sync_status == 'synced' && synced_at %>
        <span class="badge bg-success ms-1" title="Last synced: <%= synced_at %>">✓</span>
      <% elsif sync_status == 'failed' %>
        <span class="badge bg-danger ms-1">✗</span>
      <% elsif sync_status == 'pending' %>
        <span class="badge bg-warning ms-1">⚠</span>
      <% end %>
    </button>
    <!-- Pull from Remote (remote → local) - only if assistant exists -->
    <% if assistant_id.present? %>
      <button type="button"
              class="btn btn-outline-secondary"
              data-playground-sync-target="pullBtn"
              data-action="click->playground-sync#pullFromRemote"
              title="Pull latest from remote entity">
        <i class="bi bi-cloud-arrow-down"></i> Pull
      </button>
    <% end %>
  </div>

  <!-- Sync status/error container -->
  <div data-playground-sync-target="syncStatus" class="ms-2" style="display: none;"></div>
  <div data-playground-sync-target="syncError" style="display: none;"></div>
<% end %>
